# OpusHeart Configuration
NODE_ENV=production
PORT=3020

# --- Database ---
MONGO_URI=mongodb://opusheart:CHANGE_ME@mongo:27017/opusheart?authSource=admin
REDIS_URL=redis://:CHANGE_ME@redis:6379

# --- Mongo credentials (used by docker-compose/stack for container init) ---
MONGO_ROOT_USERNAME=opusheart
MONGO_ROOT_PASSWORD=CHANGE_ME

# --- Redis password (used by docker-compose/stack for container init) ---
REDIS_PASSWORD=CHANGE_ME

# --- Secrets (generate with: openssl rand -hex 32) ---
JWT_SECRET=
ENCRYPTION_KEY=

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=https://example.com

# --- Instance ---
INSTANCE_NAME=My Church
INSTANCE_URL=https://example.com
VERTICAL=church

# --- JWT (optional overrides) ---
# JWT_ISSUER=opusheart
# JWT_AUDIENCE=opusheart
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_EXPIRES=7d

# --- Feature Flags ---
FEATURE_GIVING=true
FEATURE_ATTENDANCE=true
FEATURE_MEMBER_CARE=true
FEATURE_SERMONS=true
FEATURE_GROUPS=true
FEATURE_RESOURCE_HUB=true
FEATURE_COMMUNICATION=true
FEATURE_EVENTS=true
# Connect = cross-instance federation (prayer mesh, emergency broadcasts).
# EXPERIMENTAL: inbound is signature-verified with replay protection, but
# outbound peer fan-out is not yet implemented. Keep disabled unless you are
# testing federation. See docs/privacy-and-data.md.
FEATURE_CONNECT=false
ENABLE_AI=false

# --- AI (optional — bring your own key) ---
# Supports: openai, anthropic, or any OpenAI-compatible endpoint (Ollama, LiteLLM, etc.)
# AI_PROVIDER=openai
# AI_API_KEY=your-api-key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# --- SMTP (for email communication) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# --- VAPID keys for web push (generate with: npx web-push generate-vapid-keys) ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:admin@yourchurch.org

# --- Monitoring ---
# MONITORING_TOKEN=

# --- Search (optional — Elasticsearch-backed; falls back to MongoDB if unset) ---
# Start the bundled Elasticsearch with: docker compose --profile app,search up -d
# ELASTICSEARCH_URL=http://elasticsearch:9200
