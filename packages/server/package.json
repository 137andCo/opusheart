{
  "name": "@opusheart/server",
  "version": "0.1.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && npx eslint packages/server/src",
    "test": "cd ../.. && npx jest --config jest.config.ts packages/server",
    "test:unit": "cd ../.. && npx jest --config jest.config.ts packages/server/tests/unit",
    "seed": "tsx src/scripts/seed.ts",
    "seed:demo": "tsx src/scripts/demo-seed.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.0",
    "@opusheart/ai": "workspace:*",
    "@opusheart/builder": "workspace:*",
    "@opusheart/connect": "workspace:*",
    "@opusheart/shared": "workspace:*",
    "@opusheart/vertical-church": "workspace:*",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ical-generator": "^10.0.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "nodemailer": "^8.0.4",
    "otpauth": "^9.5.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sanitize-html": "^2.17.4",
    "socket.io": "^4.8.3",
    "tweetnacl": "^1.0.3",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "supertest": "^7.2.2"
  }
}
