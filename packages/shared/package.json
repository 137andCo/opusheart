{
  "name": "@opusheart/shared",
  "version": "0.1.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": { "types": "./src/index.ts", "default": "./dist/index.js" },
    "./types": { "types": "./src/types/index.ts", "default": "./dist/types/index.js" },
    "./schemas": { "types": "./src/schemas/index.ts", "default": "./dist/schemas/index.js" },
    "./schemas/*": { "types": "./src/schemas/*", "default": "./dist/schemas/*" },
    "./constants": { "types": "./src/constants/index.ts", "default": "./dist/constants/index.js" }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && npx eslint packages/shared/src",
    "test": "cd ../.. && npx jest --config jest.config.ts packages/shared",
    "test:unit": "cd ../.. && npx jest --config jest.config.ts packages/shared"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
